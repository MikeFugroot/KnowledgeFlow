# Backend environment example. Copy to backend/.env for local development.
DATABASE_URL=sqlite+aiosqlite:///./data/knowledgeflow.db

API_PROVIDER=qwen
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DEEPSEEK_API_KEY=

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

WHISPER_BACKEND=faster_whisper
WHISPER_MODEL_CANDIDATES=large-v3,medium,small
WHISPER_LANGUAGE=zh

EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

BILIBILI_COOKIE=
XHS_COOKIE=

DATA_DIR=./data
UPLOAD_DIR=./data/uploads
READ_OUTPUT_DIR=./data/read_output
VECTOR_INDEX_DIR=./data/vector_index
WEB_CACHE_DIR=./data/web_cache

HOST=0.0.0.0
PORT=8000
